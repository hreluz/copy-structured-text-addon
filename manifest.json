{
  "manifest_version": 3,
  "name": "Copy Structured Text",
  "version": "1.4.0",
  "description": "Copy structured text from selected HTML elements.",
  "permissions": ["contextMenus", "activeTab", "clipboardWrite", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Copy Structured Text"
  },
  "web_accessible_resources": [
    {
      "resources": ["copyRules.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defaultRules.js", "ruleMerger.js", "extractText.js", "content.js"]
    }
  ]
}
