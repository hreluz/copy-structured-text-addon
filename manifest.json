{
  "manifest_version": 3,
  "name": "Copy Structured Text",
  "version": "1.4.0",
  "description": "Copy structured text from selected HTML elements.",
  "permissions": ["contextMenus", "activeTab", "clipboardWrite", "storage", "tabs"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Copy Structured Text"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/copyRules.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/defaultRules.js",
        "src/ruleMerger.js",
        "src/extractText.js",
        "src/elementSelector.js",
        "src/content.js"
      ]
    }
  ]
}
