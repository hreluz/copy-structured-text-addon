{
  "name": "copy-structured-text-addon",
  "version": "1.1.0",
  "description": "Chrome and Brave extension to copy structured text from HTML elements.",
  "scripts": {
    "test": "jest",
    "test:e2e": "jest --config jest.config.e2e.js",
    "test:e2e:watch": "PUPPETEER_HEADLESS=false PUPPETEER_SLOW_MO=600 jest --config jest.config.e2e.js --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check"
  },
  "jest": {
    "roots": [
      "<rootDir>/tests/shared",
      "<rootDir>/tests/popup",
      "<rootDir>/src"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.8.3",
    "puppeteer": "^24.42.0"
  }
}
